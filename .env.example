# ─────────────────────────────────────────────
#  KhetiBahi – Environment Variables
#  Copy this file to ".env.local" and fill in
#  real values. ".env.local" is already in
#  .gitignore by default in Next.js — never
#  commit real secrets to git.
# ─────────────────────────────────────────────

# Your MongoDB connection string.
# Local MongoDB:        mongodb://localhost:27017/khetibahi
# MongoDB Atlas (free):  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/khetibahi
MONGODB_URI=

# Secret key used to sign/verify login tokens (JWTs).
# Must be a long, random, unguessable string — anyone who has this
# string can forge a valid login token for ANY user.
# Generate one with:  openssl rand -base64 32
JWT_SECRET=
