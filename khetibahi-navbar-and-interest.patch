+export function interestDueForLoan(
+  loan: Pick<Loan, "amount" | "amountRepaid" | "dateTaken" | "interestRate" | "interestPayments">
+): number {
+  return Math.max(calculateAccruedInterest(loan) - totalInterestPaid(loan), 0);
+}
