+// helpers.ts's formatNPR() uses Intl.NumberFormat("ne-NP", ...), which
+// renders the Devanagari currency mark (रू) — jsPDF's built-in fonts
+// (Helvetica/Times/Courier) only cover Latin/WinAnsi characters, so that
+// glyph comes out as a garbled box wherever the PDF viewer doesn't do its
+// own font substitution. Desktop viewers often paper over this; strict
+// mobile viewers (Google PDF viewer, iOS Preview) don't. Rather than
+// embed a whole Devanagari-capable font just for a currency mark, the
+// PDF uses a plain "Rs." prefix instead — same grouping/rounding as
+// formatNPR, just ASCII-safe.
+function formatNPRForPDF(amount: number): string {
+  const rounded = Math.round(amount);
+  return `Rs. ${new Intl.NumberFormat("en-IN", { maximumFractionDigits: 0 }).format(rounded)}`;
+}
